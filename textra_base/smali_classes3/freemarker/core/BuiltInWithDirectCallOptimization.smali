.class abstract Lfreemarker/core/BuiltInWithDirectCallOptimization;
.super Lfreemarker/core/SpecialBuiltIn;


# direct methods
.method public constructor <init>()V
    .locals 0

    invoke-direct {p0}, Lfreemarker/core/SpecialBuiltIn;-><init>()V

    return-void
.end method


# virtual methods
.method public abstract setDirectlyCalled()V
.end method
