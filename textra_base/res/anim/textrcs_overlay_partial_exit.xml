<?xml version="1.0" encoding="utf-8"?>
<!-- Old (conv-list) screen slides part-way left while new screen overlays it.
     This is what produces the "pushed underneath" iOS/OnePlus look.
     v0.42: 280ms → 350ms; matches enter for synchronized motion.
     v0.46: added alpha 1.0→0.85 to give the underlying layer a subtle
     "dim" while the foreground covers it (iOS UINavigationController
     parallax behaviour). Against a dark app background this reads as
     a shade fading in over the underneath; on light themes it reads
     as a slight desaturation. True overlay dim would need a separate
     drawn view in ConvoActivity onCreate (not anim-XML-only). -->
<set xmlns:a="http://schemas.android.com/apk/res/android" a:shareInterpolator="true"
    a:interpolator="@android:interpolator/fast_out_slow_in"
    a:duration="350">
    <translate a:fromXDelta="0" a:toXDelta="-30%p" />
    <alpha a:fromAlpha="1.0" a:toAlpha="0.70" />
</set>
